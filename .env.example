# ─── Department Hub — backend environment (wired by Steve) ───────────────────
# The front-end is fully functional without these (it uses a localStorage mock).
# These are the values the backend server will need once it is built.

# Discord OAuth2 (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=http://localhost:3003/auth/discord/callback

# The Discord guild (server) this department lives in
DISCORD_GUILD_ID=

# Session / JWT signing
SESSION_SECRET=change-me
JWT_SECRET=change-me

# MariaDB connection
DB_HOST=localhost
DB_PORT=3306
DB_USER=department_hub
DB_PASSWORD=
DB_NAME=department_hub

# Port the API/auth server listens on (matches vite.config.js proxy)
PORT=3003
