# ─── Department Hub — backend environment ────────────────────────────────────
# Copy this file to `.env` for local dev. On Railway, set these as the service's
# Variables instead (Railway injects them — don't commit a real .env).
#
# The front-end alone works with no backend (localStorage mock). These power the
# real Express + MariaDB server in server/.

# Run the server in production mode (enables Secure cookies, disables dev login)
NODE_ENV=development

# Port the server listens on. Railway sets PORT automatically; locally use 3003
# to match vite.config.js's dev proxy.
PORT=3003

# Default department id for this deployment (config is stored under this id).
# Used when the request hostname doesn't map to a specific department — e.g. the
# Railway URL, localhost, or a one-department-per-deploy setup.
DEPARTMENT_ID=

# Domain-based multi-tenancy: serve several departments from ONE deployment, the
# request's hostname picks which config to load. Optional explicit map of
# hostname → department id. Hosts not listed fall back to the subdomain label
# (fhp.ssrp.gg → "fhp"), then to DEPARTMENT_ID. Leave blank for single-tenant.
#   DEPARTMENT_MAP=fhp.ssrp.gg=fhp,tpd.ssrp.gg=tpd,hcso.ssrp.gg=hcso
DEPARTMENT_MAP=

# ─── Discord OAuth2 (https://discord.com/developers/applications) ────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Must EXACTLY match a redirect URI in the Discord app's OAuth2 settings.
# Local:   http://localhost:3003/auth/discord/callback
# Railway: https://YOUR-APP.up.railway.app/auth/discord/callback
DISCORD_CALLBACK_URL=http://localhost:3003/auth/discord/callback

# The Discord guild (server) this department lives in — used to read each
# member's nickname + roles for group mapping.
DISCORD_GUILD_ID=

# ─── Sessions ────────────────────────────────────────────────────────────────
# Long random string. Generate one: node -e "console.log(crypto.randomUUID())"
SESSION_SECRET=change-me
# Force Secure cookies (auto-on when NODE_ENV=production). Leave blank locally.
SECURE_COOKIES=

# ─── MariaDB / MySQL ─────────────────────────────────────────────────────────
# On Railway, add a MySQL database and reference its variables here, or just set
# DATABASE_URL to ${{ MySQL.MYSQL_URL }} and leave the DB_* fields blank.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=3306
DB_USER=department_hub
DB_PASSWORD=
DB_NAME=department_hub

# ─── Discord bot rank-sync ───────────────────────────────────────────────────
# Shared secret the bot sends as `Authorization: Bearer <secret>` on
# POST /api/roster/sync. Leave blank to disable the endpoint entirely.
BOT_SYNC_SECRET=

# ─── Dev login (local testing against the real backend) ──────────────────────
# Allows POST /auth/dev-login to mint a session without Discord. Auto-OFF in
# production; never enable on a public deployment.
DEV_LOGIN_ENABLED=
