{
  "name": "ssrp-department-hub",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Modular, fully configurable department hub. Vite + React front-end with an Express + MariaDB backend (Discord auth).",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "start": "node server/index.js",
    "server": "node --watch server/index.js"
  },
  "dependencies": {
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-mysql-session": "3.0.3",
    "express-rate-limit": "8.5.2",
    "express-session": "1.19.0",
    "framer-motion": "12.40.0",
    "helmet": "8.2.0",
    "lucide-react": "1.17.0",
    "mysql2": "3.22.5",
    "passport": "0.7.0",
    "passport-oauth2": "1.8.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.0",
    "@vitejs/plugin-react": "6.0.2",
    "tailwindcss": "4.3.0",
    "vite": "8.0.16"
  }
}
